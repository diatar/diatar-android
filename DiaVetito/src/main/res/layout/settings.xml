<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent">

	<LinearLayout
		android:layout_width="fill_parent"
		android:layout_height="fill_parent"
		android:orientation="vertical">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#4BEF96"
				android:elevation="10dp"
				android:gravity="center_horizontal"
				android:paddingTop="10dp"
				android:shadowColor="#835559"
				android:shadowDx="3.0"
				android:shadowDy="3.0"
				android:shadowRadius="1.0"
				android:text="Diatár Vetítő"
				android:textAppearance="?android:attr/textAppearanceLarge"
				android:textColor="#434ECE"
				android:textStyle="bold|italic"
				android:typeface="serif" />

			<TextView
				android:id="@+id/VerTxt"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#4BEF96"
				android:gravity="center_horizontal"
				android:text="ver"
				android:textAppearance="?android:attr/textAppearanceSmall" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_gravity="center_horizontal"
				android:background="#4BEF96"
				android:gravity="center_horizontal"
				android:paddingBottom="10dp"
				android:text="Androidos segédprogram távoli vetítéshez" />

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="?android:attr/dividerVertical" />

			<TextView
				android:id="@+id/IpTxt"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal" />

		</LinearLayout>

		<androidx.gridlayout.widget.GridLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			app:alignmentMode="alignBounds"
			app:columnCount="3"
			app:columnOrderPreserved="false"
			app:useDefaultMargins="true">

			<RadioButton
				android:id="@+id/IPmode"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:onClick="onMode"
				android:text="IP"
				app:layout_column="0"
				app:layout_row="0" />

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Port:"
				app:layout_column="1"
				app:layout_gravity="right|center_vertical"
				app:layout_row="0" />

			<EditText
				android:id="@+id/PortEd"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:ems="10"
				android:gravity="center_horizontal"
				android:inputType="number"
				app:layout_column="2"
				app:layout_columnWeight="1"
				app:layout_row="0" />

			<RadioButton
				android:id="@+id/MQTTmode"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:onClick="onMode"
				android:text="Internet"
				app:layout_column="0"
				app:layout_row="1" />

			<TextView
				android:id="@+id/textView3"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Küldő:"
				app:layout_column="1"
				app:layout_gravity="right|center_vertical"
				app:layout_row="1" />

			<EditText
				android:id="@+id/SenderEd"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:ems="10"
				android:gravity="center_horizontal"
				android:inputType="text"
				app:layout_columnWeight="1"
				app:layout_column="2"
				app:layout_row="1" />

			<androidx.recyclerview.widget.RecyclerView
				android:id="@+id/SenderLst"
				android:layout_width="0dp"
				android:layout_height="129dp"
				app:layout_columnWeight="1"
				app:layout_column="2"
				app:layout_row="2" />

			<TextView
				android:id="@+id/textView2"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Csatorna:"
				app:layout_column="1"
				app:layout_gravity="right|center_vertical"
				app:layout_row="3" />

			<Spinner
				android:id="@+id/ChannelLst"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				app:layout_columnWeight="1"
				app:layout_column="2"
				app:layout_row="3" />
		</androidx.gridlayout.widget.GridLayout>

		<View
			android:id="@+id/divider"
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?android:attr/listDivider" />

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="horizontal">

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="center_vertical"
				android:text="Margók:"
				android:textAppearance="?android:attr/textAppearanceMedium" />

			<CheckBox
				android:id="@+id/B2CCk"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:onClick="onB2C"
				android:text="Vezérlő küldi" />

		</LinearLayout>

		<GridLayout
			columnCount="1"
			rowCount="1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:columnCount="4"
			android:rowCount="3">

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="0"
				android:layout_column="0"
				android:layout_gravity="right|center_vertical"
				android:text="Bal:" />

			<EditText
				android:id="@+id/ClipL"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="0"
				android:layout_column="1"
				android:ems="5"
				android:inputType="numberDecimal" />

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="0"
				android:layout_column="2"
				android:layout_gravity="right|center_vertical"
				android:text="Jobb:" />

			<EditText
				android:id="@+id/ClipR"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:ems="5"
				android:inputType="numberDecimal" />

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="1"
				android:layout_column="0"
				android:layout_gravity="right|center_vertical"
				android:text="Felső:" />

			<EditText
				android:id="@+id/ClipT"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="1"
				android:layout_column="1"
				android:ems="5"
				android:inputType="numberDecimal" />

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="1"
				android:layout_column="2"
				android:layout_gravity="right|center_vertical"
				android:text="Alsó:" />

			<EditText
				android:id="@+id/ClipB"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="1"
				android:layout_column="3"
				android:ems="5"
				android:inputType="numberDecimal" />

			<CheckBox
				android:id="@+id/MirrorCb"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="2"
				android:layout_column="0"
				android:layout_columnSpan="2"
				android:layout_gravity="center_vertical|center_horizontal"
				android:text="Tükrözés" />

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_row="2"
				android:layout_column="2"
				android:layout_gravity="right|center_vertical"
				android:text="Forgatás:" />

			<Spinner
				android:id="@+id/RotLst"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:entries="@array/setrotate" />

		</GridLayout>

		<View
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?android:attr/dividerVertical" />

		<CheckBox
			android:id="@+id/BootCk"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Automatikus indítás bekapcsoláskor" />

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal">

			<Button
				android:id="@+id/btnStop"
				style="?android:attr/buttonStyleSmall"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_weight="1.0"
				android:onClick="onExit"
				android:text="Kilép" />

			<Button
				android:id="@+id/btnShutdown"
				style="?android:attr/buttonStyleSmall"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_weight="1.0"
				android:onClick="onShutdown"
				android:text="Leállít"
				android:visibility="visible" />

			<Button
				android:id="@+id/btnReboot"
				style="?android:attr/buttonStyleSmall"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_weight="1.0"
				android:onClick="onReboot"
				android:text="Újraindít"
				android:visibility="visible" />

		</LinearLayout>

		<TextView
			android:id="@+id/textView"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center"
			android:text="(Figyelem! A leállítás és újraindítás védett funkció, csak Root-olt készüléken elképzelhető)" />

		<LinearLayout
			style="?android:attr/buttonBarStyle"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal">

			<Button
				style="?android:attr/buttonBarButtonStyle"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_weight="1.0"
				android:onClick="onCancel"
				android:text="Mégse" />

			<Button
				style="?android:attr/buttonBarButtonStyle"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_weight="1.0"
				android:onClick="onOk"
				android:text="Ok" />

		</LinearLayout>

	</LinearLayout>

</ScrollView>

