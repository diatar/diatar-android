<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Kattintás (nyomva tartás) -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#DDDDDD"/> <!-- középszürke -->
        </shape>
    </item>

    <!-- Kiválasztott -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#BBDEFB"/> <!-- világoskék highlight -->
        </shape>
    </item>

    <!-- Fókusz (pl. tab navigáció) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#EEEEEE"/> <!-- nagyon világosszürke -->
        </shape>
    </item>

    <!-- Alapértelmezett -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/> <!-- fehér -->
        </shape>
    </item>
</selector>
